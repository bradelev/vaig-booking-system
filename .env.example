# WhatsApp Business API (Meta Cloud API)
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_APP_SECRET=
WHATSAPP_WEBHOOK_SECRET=
WHATSAPP_PHONE_NUMBER_ID=

# Google Calendar API (Service Account)
GOOGLE_SERVICE_ACCOUNT_EMAIL=
