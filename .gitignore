# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files
.env*
!.env.example

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# Claude Code — contains secrets (API tokens)
.claude/mcp_settings.json

# Claude Code local project data (not source code)
.claude/

# Skills lock (local tooling)
skills-lock.json

# Client data and internal docs — never commit
docs/*.csv
docs/*.xlsx
docs/clients_rows.csv
docs/PROJECT-CONTEXT.md
docs/CLAUDE.md
docs/GUIA-DE-USUARIO.md
docs/vaig_booking_system_PRD_v1.3.md
docs/mcp-and-skills-setup.md
docs/vaig_jira_issues.csv
scripts/*.csv
scripts/migration-errors.csv

# Allow the screenshots folder
!docs/screenshots/
!docs/screenshots/**

# Loose screenshots at root
image*.png
Screenshot*.png
*.jpeg
captura-*.jpg
